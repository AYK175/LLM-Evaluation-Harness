# Fill in only the providers you actually use; leave the rest blank.

# Free Gemini key (no credit card) from https://aistudio.google.com
GEMINI_API_KEY=

# Paid providers (optional — not needed for the free local+Gemini setup)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
TOGETHER_API_KEY=

# Ollama runs locally; no key needed. Override only if not on the default port.
# OLLAMA_BASE_URL=http://localhost:11434/v1
